# ── Single-connection (legacy MSSQL) ──────────────────────────────────────────
# MSSQL_CONNECTION_STRING="Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=mydb;UID=sa;PWD=..."
# READ_ONLY=true
# ENABLE_WRITES=false
# ADMIN_CONFIRM=

# ── Multi-connection (JSON array) ─────────────────────────────────────────────
# SQL_MCP_CONNECTIONS='[
#   {"id":"prod_sql","engine":"mssql","dsn":"Driver=...","read_only":true,"description":"Production SQL Server"},
#   {"id":"analytics_pg","engine":"postgres","dsn":"postgresql://user:pass@host:5432/db","read_only":true},
#   {"id":"dev_mysql","engine":"mysql","dsn":"mysql://root:pass@localhost:3306/dev","read_only":false}
# ]'

# ── Server ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# ENABLE_METRICS=true
# MAX_QUERY_LENGTH=50000
